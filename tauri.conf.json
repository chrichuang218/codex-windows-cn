{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Windows 中文助手",
  "version": "0.1.2",
  "identifier": "io.github.chrichuang218.codex-windows-cn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "./frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Windows 中文助手",
        "width": 920,
        "height": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
